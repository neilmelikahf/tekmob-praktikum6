<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ios/Runner/Info.plist
  Konfigurasi izin (NSUsageDescription) untuk iOS.
  WAJIB diisi agar Apple tidak menolak akses ke sensor perangkat.
-->
<plist version="1.0">
<dict>
    <!-- ═══════════════════════════════════
         IZIN KAMERA (image_picker)
         ═══════════════════════════════════ -->
    <key>NSCameraUsageDescription</key>
    <string>Aplikasi membutuhkan akses kamera untuk mengambil foto bukti laporan lapangan.</string>

    <!-- Akses galeri untuk memilih foto yang sudah ada -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Aplikasi membutuhkan akses galeri untuk memilih foto bukti laporan.</string>

    <!-- Izin menulis ke galeri (jika foto perlu disimpan) -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Aplikasi membutuhkan izin untuk menyimpan foto laporan ke galeri.</string>

    <!-- ═══════════════════════════════════
         IZIN LOKASI GPS (geolocator)
         ═══════════════════════════════════ -->
    <!-- Lokasi saat aplikasi aktif di foreground -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Aplikasi membutuhkan akses lokasi GPS untuk mencatat koordinat kejadian yang dilaporkan.</string>

    <!-- Lokasi secara presisi (Always — opsional untuk background) -->
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Aplikasi membutuhkan akses lokasi GPS untuk mencatat koordinat titik laporan lapangan.</string>

    <!-- ═══════════════════════════════════
         KONFIGURASI FLUTTER STANDAR
         ═══════════════════════════════════ -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>Laporan Lapangan</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- Allow checking for Google Maps URL scheme -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>comgooglemaps</string>
    </array>
</dict>
</plist>
